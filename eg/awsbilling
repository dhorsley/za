def show_region_menu(profile, current_region)
    heading("Select Region", "Fetching regions...")

    regions, rerr = discover_regions(profile)
    if len(regions) == 0
        if rerr != ""
            heading_err("Select Region", rerr)
        else
            heading_err("Select Region", "No regions found. Is Cost Explorer enabled?")
        endif
        at 5, 1
        println "[#3]Press any key...[##][#-]"
        keypress()
        return current_region, true
    endif

    heading("Select Region", "Enter=select  Q=cancel")

    opts = []
    foreach r in regions
        lbl = r["label"]
        on lbl == nil do lbl = r["code"]
        append_to(ref opts, "  {lbl}  ")
    endfor
    append_to(ref opts, "  [back]  ")

    m = map(.row 4, .col 4, .title "AWS Regions", .height 0, .width 50,
            .options opts, .prompt "Select region:", .cursor "[#b1][#6]>[##][#-]", .index 0, .border true)
    s = map(.fill true, .bg "0", .fg "7", .hi_bg "1", .hi_fg "6",
             .border map(.bg "0", .fg "7"))

    menu = tui_menu(m, s)
    on menu.Cancel do return current_region, true
    idx = menu.Result - 1
    on idx < 0 || idx >= len(regions) do return current_region, true
    code = regions[idx]["code"]
    on code == nil do return current_region, true
    return code, false
end

