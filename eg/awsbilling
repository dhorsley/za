# --- TUI helpers ---

def heading(subtitle, hint)
    cls
    at 1, 1
    println "[#b1][#6]  AWS Billing - ", subtitle, "  [##][#-]"
    at 2, 1
    println "[#3]", hint, "[##][#-]"
end

def heading_err(subtitle, msg)
