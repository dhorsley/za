def anomaly_flag(cost, prev_cost)
    on prev_cost == nil do return ""
    on prev_cost == 0.0 do return ""
    on cost > prev_cost * 1.5 do return " \u25b2"
    return ""
end

def fetch_service_daily(profile, region, service_name, start, endt)
    args = "get-cost-and-usage --time-period Start={start},End={endt} --granularity DAILY --metrics AmortizedCost"
    filter_expr = json_encode(map(.And [
        map(.Dimensions map(.Key "REGION", .Values [region])),
        map(.Dimensions map(.Key "SERVICE", .Values [service_name]))
    ]))
    on region != "" do args = args + " --filter '" + filter_expr + "'"
    on region == "" do args = args + " --filter '" + json_encode(map(.Dimensions map(.Key "SERVICE", .Values [service_name]))) + "'"
    data, err = aws_ce(profile, args)
    on data == nil do return nil, 0.0, err
    results = data["ResultsByTime"]
    on results == nil do return nil, 0.0, "No ResultsByTime"
    days = []
    max_cost = 0.0
    foreach period in results
        amount_str = period["Total"]["AmortizedCost"]["Amount"]
        continue if amount_str == nil
        amount = as_float(amount_str)
        date_str = period["TimePeriod"]["Start"]
        on date_str == nil do date_str = "?"
        append_to(ref days, map(.date date_str, .cost amount))
        on amount > max_cost do max_cost = amount
    endfor
    return days, max_cost, nil
end

def fetch_day_services(profile, region, date_str)
    next_d = next_day(date_str)
    args = "get-cost-and-usage --time-period Start={date_str},End={next_d} --granularity DAILY --metrics AmortizedCost --group-by Type=DIMENSION,Key=SERVICE"
    on region != "" do args = args + " --filter '" + json_encode(map(.Dimensions map(.Key "REGION", .Values [region]))) + "'"
    data, err = aws_ce(profile, args)
    on data == nil do return nil, 0.0, err
    results = data["ResultsByTime"]
    on results == nil do return nil, 0.0, "No ResultsByTime"
    on len(results) == 0 do return nil, 0.0, "Empty ResultsByTime"
    period = results[0]
    groups = period["Groups"]
    on groups == nil do return nil, 0.0, "No Groups"
    on len(groups) == 0 do return nil, 0.0, "No cost data"
    services = []
    total = 0.0
    max_cost = 0.0
    foreach g in groups
        amount_str = g["Metrics"]["AmortizedCost"]["Amount"]
        continue if amount_str == nil
        amount = as_float(amount_str)
        svc = g["Keys"][0]
        on svc == nil do svc = "Unknown"
        append_to(ref services, costrow(
            .service svc,
            .cost amount,
            .cost_str "",
            .pct "",
            .pct_val 0.0,
            .sort_val amount,
            .bar ""
        ))
        total = total + amount
        on amount > max_cost do max_cost = amount
    endfor
    on len(services) == 0 do return nil, 0.0, "No cost data parsed"
    for i = 0 to len(services) - 1
        pct_val = 0.0
        on total > 0 do pct_val = services[i].cost / total * 100.0
        services[i].pct_val = pct_val
        services[i].pct = "{=as_string(pct_val.as_bigf, 1)}%"
    endfor
    sort_costs(services, "cost_desc")
    return services, max_cost, nil
end

def render_mini_chart(days, max_cost, curr_code)
    if len(days) == 0
        return "No daily data"
    endif
    lines = []
    foreach d in days
        bar = ""
        on max_cost > 0 do bar = progress_bar(d.cost / max_cost * 100.0, 20, "\u2588", "\u2591")
        append_to(ref lines, "  " + d.date + "  " + convert_and_fmt(d.cost, curr_code) + "  " + bar)
    endfor
    return join(lines, "\n")
end

def partial_block(frac)
    on frac >= 0.875 do return "\u2587"
    on frac >= 0.625 do return "\u2586"
    on frac >= 0.375 do return "\u2585"
    on frac >= 0.125 do return "\u2583"
    return "\u2581"
end

def render_daily_chart(all_costs, max_cost, curr_code, selected_date, start_row, start_col)
    n = len(all_costs)
    on n == 0 do return map(.text "No daily data", .lines 1)

    # Keep chronological order (API already provides this)
    chart_costs = all_costs

    # Dimensions
    label_w = 8
    margin = label_w + 2
    chart_h = term_h() - 14
    on chart_h > 15 do chart_h = 15
    on chart_h < 4 do chart_h = 4

    on max_cost < 0.001 do max_cost = 0.001

    parts = []
    label_interval = chart_h / 4
    on label_interval < 1 do label_interval = 1

    # Y-axis labels and bar rows
    for row = 0 to chart_h - 1
        # Compute cost at this row level (from top down)
        frac_from_top = row.as_float / chart_h.as_float
        row_cost = max_cost * (1.0 - frac_from_top)
        label = convert_and_fmt(row_cost, curr_code)
        if len(label) > label_w
            label = substr(label, 0, label_w)
        endif
        label = pad(label, -1, label_w, " ")

        if row == 0 || row == chart_h - 1 || (row % label_interval == 0)
            append_to(ref parts, pos(start_row + row, start_col) + label + " \u2502")
        else
            append_to(ref parts, pos(start_row + row, start_col) + pad("", -1, label_w, " ") + " \u2502")
        endif

        # Draw bar cells for this row
        for col = 0 to n - 1
            cost = chart_costs[col].cost
            bar_h = cost / max_cost * chart_h.as_float
            full = as_int(bar_h)
            frac = bar_h - full.as_float

            # Is this row part of this bar?
            # row 0 is top, row chart_h-1 is bottom
            bar_top = chart_h - 1 - full
            if frac > 0.0 && full < chart_h
                bar_top = bar_top - 1
            endif

            if row >= bar_top && row <= chart_h - 1
                cell = "\u2588"
                if row == bar_top && frac > 0.0 && full < chart_h
                    cell = partial_block(frac)
                endif
                if selected_date != "" && chart_costs[col].service == selected_date
                    cell = "[#6]" + cell + "[#-]"
                endif
                append_to(ref parts, pos(start_row + row, start_col + margin + col * 3 + 1) + cell)
            endif
        endfor
    endfor

    # Zero line
    zero_label = pad(convert_and_fmt(0.0, curr_code), -1, label_w, " ")
    append_to(ref parts, pos(start_row + chart_h, start_col) + zero_label + " \u253c")
    for c = 0 to n * 3 - 1
        append_to(ref parts, pos(start_row + chart_h, start_col + margin + c) + "\u2500")
    endfor

    # Day numbers
    for col = 0 to n - 1
        day_str = substr(chart_costs[col].service, 8, 2)
        append_to(ref parts, pos(start_row + chart_h + 1, start_col + margin + col * 3) + day_str)
    endfor

    return map(.text join(parts, ""), .lines chart_h + 2)
end

def svc_color(idx)
    colors = [
        fgrgb(255, 50, 50),   fgrgb(50, 255, 50),   fgrgb(50, 50, 255),
        fgrgb(255, 200, 0),   fgrgb(255, 0, 255),   fgrgb(0, 255, 255),
        fgrgb(255, 100, 0),   fgrgb(200, 50, 200),  fgrgb(100, 255, 100),
        fgrgb(100, 100, 255), fgrgb(255, 255, 50),  fgrgb(255, 50, 150),
        fgrgb(50, 200, 200),  fgrgb(200, 150, 50),  fgrgb(150, 50, 255),
        fgrgb(50, 255, 150),  fgrgb(255, 150, 100), fgrgb(100, 150, 255),
        fgrgb(200, 255, 50),  fgrgb(255, 100, 100)
    ]
    return colors[idx % 20]
end

def render_service_chart(services, max_cost, curr_code, start_row, start_col, max_h, legend_name_width)
    n = len(services)
    on n == 0 do return map(.text "No service data", .lines 1)

    # Keep only >$0
    filtered = []
    foreach s in services
        on s.cost > 0.0 do append_to(ref filtered, s)
    endfor
    n = len(filtered)
    on n == 0 do return map(.text "No service costs", .lines 1)

    # Dimensions
    label_w = 8
    margin = label_w + 2
    chart_h = max_h
    on chart_h > 20 do chart_h = 20
    on chart_h < 4 do chart_h = 4

    on max_cost < 0.001 do max_cost = 0.001

    parts = []
    label_interval = chart_h / 4
    on label_interval < 1 do label_interval = 1

    # Y-axis labels and bars
    for row = 0 to chart_h - 1
        frac_from_top = row.as_float / chart_h.as_float
        row_cost = max_cost * (1.0 - frac_from_top)
        label = convert_and_fmt(row_cost, curr_code)
        if len(label) > label_w
            label = substr(label, 0, label_w)
        endif
        label = pad(label, -1, label_w, " ")

        if row == 0 || row == chart_h - 1 || (row % label_interval == 0)
            append_to(ref parts, pos(start_row + row, start_col) + label + " \u2502")
        else
            append_to(ref parts, pos(start_row + row, start_col) + pad("", -1, label_w, " ") + " \u2502")
        endif

        for col = 0 to n - 1
            cost = filtered[col].cost
            bar_h = cost / max_cost * chart_h.as_float
            full = as_int(bar_h)
            frac = bar_h - full.as_float

            bar_top = chart_h - 1 - full
            if frac > 0.0 && full < chart_h
                bar_top = bar_top - 1
            endif

            if row >= bar_top && row <= chart_h - 1
                cell = "\u2588"
                if row == bar_top && frac > 0.0 && full < chart_h
                    cell = partial_block(frac)
                endif
                color = svc_color(col)
                append_to(ref parts, pos(start_row + row, start_col + margin + col * 2) + color + cell + "[#-]")
            endif
        endfor
    endfor

    # Zero line
    zero_label = pad(convert_and_fmt(0.0, curr_code), -1, label_w, " ")
    append_to(ref parts, pos(start_row + chart_h, start_col) + zero_label + " \u253c")
    for c = 0 to n * 2 - 1
        append_to(ref parts, pos(start_row + chart_h, start_col + margin + c) + "\u2500")
    endfor

    # Multi-column legend
    legend_entries = []
    max_legend = 20
    shown = 0
    foreach s in filtered
        if shown >= max_legend
            break
        endif
        cost_str = convert_and_fmt(s.cost, curr_code)
        name = trunc(s.service, legend_name_width, "\u2026")
        swatch = svc_color(shown) + "\u2588\u2588" + "[#-]"
        entry = swatch + " " + pad(name, 1, legend_name_width, " ") + " " + cost_str
        append_to(ref legend_entries, entry)
        shown = shown + 1
    endfor
    if len(filtered) > max_legend
        append_to(ref legend_entries, "... and " + as_string(len(filtered) - max_legend) + " more")
    endif

    entry_w = 2 + 1 + legend_name_width + 1 + 12 + 2  # swatch + space + name + space + cost + pad
    per_row = (term_w() - 4) / entry_w
    on per_row < 1 do per_row = 1

    legend_row = 0
    for i = 0 to len(legend_entries) - 1
        col_in_row = i % per_row
        if col_in_row == 0
            legend_row = legend_row + 1
        endif
        append_to(ref parts, pos(start_row + chart_h + 1 + legend_row, start_col + col_in_row * entry_w) + legend_entries[i])
    endfor

    return map(.text join(parts, ""), .lines chart_h + 1 + legend_row + 1)
end

def show_monthly_chart(all_costs, curr_code, period_lbl, hide_zero)
    chart_costs = []
    max_cost = 0.0
    foreach c in all_costs
        on hide_zero && c.cost == 0.0 do continue
        append_to(ref chart_costs, c)
        on c.cost > max_cost do max_cost = c.cost
    endfor
    on len(chart_costs) == 0 do return

    sort_costs(chart_costs, "cost_desc")

    heading("Monthly Cost Breakdown", "V=table  Q=quit")
    at 2, 1
    println "[#3]  Period: ", period_lbl, "  Total services: ", as_string(len(chart_costs)), "  [##][#-]"

    if term_w() >= 100
        chart_res = render_service_chart(chart_costs, max_cost, curr_code, 4, 2, term_h() - 8, 25)
        print "[#2]", chart_res.text, "[##][#-]"
    else
        lines = []
        foreach c in chart_costs
            bar = ""
            on max_cost > 0 do bar = progress_bar(c.cost / max_cost * 100.0, 20, "\u2588", "\u2591")
            append_to(ref lines, "  " + trunc(c.service, 30, "\u2026") + "  " + convert_and_fmt(c.cost, curr_code) + "  " + bar)
        endfor
        at 5, 2
        println "[#2]", join(lines, "\n"), "[##][#-]"
    endif

    at term_h() - 1, 2
    println "[#3]Press any key to return...[##][#-]"
    keypress()
end

