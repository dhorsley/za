    endfor
    append_to(ref opts, "  [back]  ")

    m = map(.row 4, .col 4, .title "AWS Profiles", .height 0, .width 40,
            .options opts, .prompt "Select profile:", .cursor "[#b1][#6]>[##][#-]", .index 0, .border true)
