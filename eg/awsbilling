struct costrow
    service     string
    cost        float
    cost_str    string
    pct         string
    pct_val     float
    sort_val    float
    bar         string

es

# --- Sorting ---

def sort_costs(costs, mode)
    n = len(costs)
    on n < 2 do return
    for i = 0 to n - 2
        for j = 0 to n - i - 2
            swap = false
            if mode == "name"
                a = lower(costs[j].service)
                b = lower(costs[j+1].service)
                on a > b do swap = true
            else
                a = costs[j].sort_val
                b = costs[j+1].sort_val
                if mode == "cost_desc"
                    on a < b do swap = true
                else
                    on a > b do swap = true
                endif
            endif
            if swap
                tmp = costs[j]
                costs[j] = costs[j+1]
                costs[j+1] = tmp
            endif
        endfor
    endfor
end

# --- AWS helpers ---

def check_aws_cli()
    result =| aws --version 2>&1
    return result.okay
end

def aws_ce(profile, args)
    cmd = "aws ce " + args + " --output json 2>&1"
    on profile != "" do cmd = "AWS_PROFILE={profile} " + cmd
    result =| {cmd}
    if not result.okay
        err_msg = result.err
        on err_msg == "" do err_msg = $st result.out
        return nil, err_msg
    endif
    return json_decode(result.out), nil
end

def discover_profiles()
    profiles = []
    creds_path = home() + "/.aws/credentials"
    config_path = home() + "/.aws/config"
    
    if is_file(creds_path)
        raw = $in creds_path
        lines = split(raw, "\n")
        foreach line in lines
            line = replace(line, "^\s+|\s+$", "")
            continue if not line ~ "^\["
            name = replace(line, "^\[", "")
            name = replace(name, "\]$", "")
            on not name in profiles do append_to(ref profiles, name)
        endfor
    endif
    
    if is_file(config_path)
        raw = $in config_path
        lines = split(raw, "\n")
        foreach line in lines
            line = replace(line, "^\s+|\s+$", "")
            continue if not line ~ "^\[profile\s"
            name = replace(line, "^\[profile\s+", "")
            name = replace(name, "\]$", "")
            on not name in profiles do append_to(ref profiles, name)
        endfor
    endif
    
    return profiles
end

def discover_regions(profile)
    regions = []
    cy = as_string(time_year())
    cm = as_int(time_month())
    sm = cm - 3
    sy = cy
    if sm < 1
        sm = sm + 12
    endif
    if sm > cm
        sy = as_string(as_int(cy) - 1)
    endif
    start_str = `{sy}-{=pad(as_string(sm), 1, 2, "0")}-01`
    end_str = `{cy}-{=pad(as_string(cm), 1, 2, "0")}-01`
    args = `get-dimension-values --dimension REGION --time-period Start={start_str},End={end_str}`
    data, err = aws_ce(profile, args)
    if data == nil
        return regions, "aws ce failed: " + err
    endif
    vals = data["DimensionValues"]
    on vals == nil do return regions, "No DimensionValues in AWS response"
    foreach v in vals
        code = v["Value"]
        continue if code == nil
        continue if code == ""
        label = code
        attrs = data["DimensionValueAttributes"]
        if attrs != nil
            foreach a in attrs
                continue if a["Value"] != code
                dn = a["Attributes"]["displayName"]
                on dn != nil do label = "{dn} ({code})"
            endfor
        endif
        append_to(ref regions, map(.code code, .label label))
    endfor
    return regions, ""
end

def fetch_costs(profile, region, start, endt)
    args = "get-cost-and-usage --time-period Start={start},End={endt} --granularity MONTHLY --metrics AmortizedCost --group-by Type=DIMENSION,Key=SERVICE"
    on region != "" do args = args + " --filter '" + json_encode(map(.Dimensions map(.Key "REGION", .Values [region]))) + "'"
    data, err = aws_ce(profile, args)
    on data == nil do return nil, err
    return parse_costs(data)
end

