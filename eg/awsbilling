end

def parse_costs(data)
    results = data["ResultsByTime"]
    on results == nil do return nil, "No ResultsByTime in response"
    on len(results) == 0 do return nil, "Empty ResultsByTime"
    period = results[0]
    groups = period["Groups"]
    on groups == nil do return nil, "No Groups in response"
    on len(groups) == 0 do return nil, "No cost data found"
    costs = []
    total = 0.0
    foreach g in groups
        amount_str = g["Metrics"]["AmortizedCost"]["Amount"]
        continue if amount_str == nil
        amount = as_float(amount_str)
        svc_name = g["Keys"][0]
        on svc_name == nil do svc_name = "Unknown"
        append_to(ref costs, costrow(
            .service svc_name,
            .cost amount,
            .cost_str "",
            .pct "",
            .pct_val 0.0,
            .sort_val amount,
            .bar ""
        ))
        total = total + amount
    endfor
    on len(costs) == 0 do return nil, "No cost data parsed"
    for i = 0 to len(costs)-1
        pct_val = 0.0
        on total > 0 do pct_val = costs[i].cost / total * 100.0
        costs[i].pct_val = pct_val
        pct_str = "{=as_string(pct_val.as_bigf, 3)}%"
        on pct_str ~ "e-" do pct_str = "<0.001%"
        costs[i].pct = pct_str
        costs[i].bar = progress_bar(pct_val, 20, "\u2588", "\u2591")
    endfor
    sort_costs(costs, "cost_desc")
    return costs, nil
end

def parse_daily_costs(data)
    results = data["ResultsByTime"]
    on results == nil do return nil, 0.0, "No ResultsByTime in response"
    on len(results) == 0 do return nil, 0.0, "Empty ResultsByTime"
    costs = []
    total = 0.0
    max_cost = 0.0
    foreach period in results
        amount_str = period["Total"]["AmortizedCost"]["Amount"]
        continue if amount_str == nil
        amount = as_float(amount_str)
        date_label = period["TimePeriod"]["Start"]
        on date_label == nil do date_label = "Unknown"
        append_to(ref costs, costrow(
            .service date_label,
            .cost amount,
            .cost_str "",
            .pct "",
            .pct_val 0.0,
            .sort_val amount,
            .bar ""
        ))
        total = total + amount
        on amount > max_cost do max_cost = amount
    endfor
    on len(costs) == 0 do return nil, 0.0, "No cost data parsed"
    for i = 0 to len(costs)-1
        pct_val = 0.0
        on total > 0 do pct_val = costs[i].cost / total * 100.0
        costs[i].pct_val = pct_val
        pct_str = "{=as_string(pct_val.as_bigf, 3)}%"
        on pct_str ~ "e-" do pct_str = "<0.001%"
        costs[i].pct = pct_str
        bar_pct = 0.0
        on max_cost > 0 do bar_pct = costs[i].cost / max_cost * 100.0
        costs[i].bar = progress_bar(bar_pct, 20, "\u2588", "\u2591")
    endfor
    return costs, max_cost, nil
end

def parse_forecast(data)
    total = data["Total"]
    on total == nil do return nil, "No Total in forecast"
    amount_str = total["Amount"]
    on amount_str == nil do return nil, "No Amount in forecast"
    return as_float(amount_str), nil
end

def parse_prev_month_costs(data)
    results = data["ResultsByTime"]
    on results == nil do return nil, "No ResultsByTime"
    on len(results) == 0 do return nil, "Empty ResultsByTime"
    period = results[0]
    groups = period["Groups"]
    on groups == nil do return nil, "No Groups"
    prev = map()
    foreach g in groups
        amount_str = g["Metrics"]["AmortizedCost"]["Amount"]
        continue if amount_str == nil
        svc = g["Keys"][0]
        on svc == nil do svc = "Unknown"
        prev[svc] = as_float(amount_str)
    endfor
    return prev, nil
end

def try_load_from_cache(profile, region, cost_start, cost_endt, forecast_start, forecast_endt, sort_mode, granularity)
    cache_tag = "costs"
    if granularity == "DAILY"
        cache_tag = "daily_costs"
    endif

    cached_data = cache_load(profile, region, cost_start, cost_endt, granularity, cache_tag)
    if cached_data == nil
        return nil
    endif

    if granularity == "DAILY"
        costs, max_cost, err = parse_daily_costs(cached_data)
    else
        costs, err = parse_costs(cached_data)
        max_cost = 0.0
    endif

    if costs == nil || len(costs) == 0
        return nil
    endif

    forecast_data = cache_load(profile, region, forecast_start, forecast_endt, "MONTHLY", "forecast")
    forecast = nil
    if forecast_data != nil
        forecast, _ = parse_forecast(forecast_data)
    endif

    prev_data = cache_load(profile, region, cost_start, cost_endt, granularity, "prev_month")
    prev_map = nil
    if prev_data != nil
        prev_map, _ = parse_prev_month_costs(prev_data)
    endif

    sort_costs(costs, sort_mode)
    on granularity != "DAILY" do max_cost = 0.0
    return map(.costs costs, .forecast forecast, .prev_costs_map prev_map, .max_cost max_cost, .err nil)
end

def async_fetch(profile, region, cost_start, cost_endt, forecast_start, forecast_endt, sort_mode, granularity, force_refresh)
    cache_tag = "costs"
    if granularity == "DAILY"
        cache_tag = "daily_costs"
    endif

    costs = nil
    max_cost = 0.0
    err = nil

    # Fetch fresh cost data
    if granularity == "DAILY"
        args = "get-cost-and-usage --time-period Start={cost_start},End={cost_endt} --granularity DAILY --metrics AmortizedCost"
        on region != "" do args = args + " --filter '" + json_encode(map(.Dimensions map(.Key "REGION", .Values [region]))) + "'"
        data, err = aws_ce(profile, args)
        on data == nil do return map(.costs nil, .forecast nil, .prev_costs_map nil, .max_cost 0.0, .err err)
        cache_save(profile, region, cost_start, cost_endt, granularity, cache_tag, data)
        costs, max_cost, err = parse_daily_costs(data)
    else
        args = "get-cost-and-usage --time-period Start={cost_start},End={cost_endt} --granularity MONTHLY --metrics AmortizedCost --group-by Type=DIMENSION,Key=SERVICE"
        on region != "" do args = args + " --filter '" + json_encode(map(.Dimensions map(.Key "REGION", .Values [region]))) + "'"
        data, err = aws_ce(profile, args)
        on data == nil do return map(.costs nil, .forecast nil, .prev_costs_map nil, .max_cost 0.0, .err err)
        cache_save(profile, region, cost_start, cost_endt, granularity, cache_tag, data)
        costs, err = parse_costs(data)
        max_cost = 0.0
    endif
    on costs == nil do return map(.costs nil, .forecast nil, .prev_costs_map nil, .max_cost 0.0, .err err)
    sort_costs(costs, sort_mode)

    # Fetch and cache forecast
    fargs = "get-cost-forecast --time-period Start={forecast_start},End={forecast_endt} --metric AMORTIZED_COST --granularity MONTHLY"
    on region != "" do fargs = fargs + " --filter '" + json_encode(map(.Dimensions map(.Key "REGION", .Values [region]))) + "'"
    forecast_data, ferr = aws_ce(profile, fargs)
    forecast = nil
    if forecast_data != nil
        cache_save(profile, region, forecast_start, forecast_endt, "MONTHLY", "forecast", forecast_data)
        forecast, _ = parse_forecast(forecast_data)
    endif

    # Fetch and cache previous month
    prev_start, prev_end = prev_period(cost_start)
    pargs = "get-cost-and-usage --time-period Start={prev_start},End={prev_end} --granularity MONTHLY --metrics AmortizedCost --group-by Type=DIMENSION,Key=SERVICE"
    on region != "" do pargs = pargs + " --filter '" + json_encode(map(.Dimensions map(.Key "REGION", .Values [region]))) + "'"
    prev_data, _ = aws_ce(profile, pargs)
    prev_map = nil
    if prev_data != nil
        cache_save(profile, region, cost_start, cost_endt, granularity, "prev_month", prev_data)
        prev_map, _ = parse_prev_month_costs(prev_data)
    endif

    on granularity != "DAILY" do max_cost = 0.0
    return map(.costs costs, .forecast forecast, .prev_costs_map prev_map, .max_cost max_cost, .err nil)
end

def async_load(profile, region, cost_start, cost_endt, forecast_start, forecast_endt, sort_mode, granularity, force_refresh)
    if not force_refresh
        cached_result = try_load_from_cache(profile, region, cost_start, cost_endt, forecast_start, forecast_endt, sort_mode, granularity)
        if cached_result != nil
            heading("Loading", "Please wait...")
            spinner_show("Loading from cache")
            pause 100
            spinner_clear()
            return cached_result
        endif
    endif

    heading("Loading", "Please wait...")
    var h map
    ASYNC h async_fetch(profile, region, cost_start, cost_endt, forecast_start, forecast_endt, sort_mode, granularity, force_refresh) "result"
    cursoroff()
    while
        if force_refresh
            spinner_show("Refreshing cost data")
        else
            spinner_show("Fetching cost data")
        endif
        res = await(ref h, false)
        break if len(h) == 0
        pause 50
    endwhile
    spinner_clear()
    return res["result"]
end

# --- Date helpers ---

def this_month_period()
    y = as_string(time_year())
    m = pad(as_string(time_month()), 1, 2, "0")
    start = "{y}-{m}-01"
    nm = time_month() + 1
    ny = y
    if nm > 12
        nm = 1
        ny = as_string(time_year() + 1)
    endif
    nms = pad(as_string(nm), 1, 2, "0")
    end_str = "{ny}-{nms}-01"
    return start, end_str
end

def prev_month_period()
    y = as_string(time_year())
    m = time_month()
    pm = m - 1
    py = y
    if pm < 1
        pm = 12
        py = as_string(as_int(y) - 1)
    endif
    start = `{py}-{=pad(as_string(pm), 1, 2, "0")}-01`
    end_str = `{y}-{=pad(as_string(m), 1, 2, "0")}-01`
    return start, end_str
end

def forecast_period()
    y = as_string(time_year())
    m = pad(as_string(time_month()), 1, 2, "0")
    d = pad(as_string(time_dom()), 1, 2, "0")
    start = "{y}-{m}-{d}"
    nm = time_month() + 1
    ny = y
    if nm > 12
        nm = 1
        ny = as_string(time_year() + 1)
    endif
    nms = pad(as_string(nm), 1, 2, "0")
    end_str = "{ny}-{nms}-01"
    return start, end_str
end

def prev_period(start)
    y = as_int(substr(start, 0, 4))
    m = as_int(substr(start, 5, 2))
    m = m - 1
    if m < 1
        m = 12
        y = y - 1
    endif
    ps = as_string(y) + "-" + pad(as_string(m), 1, 2, "0") + "-01"
    nm = m + 1
    ny = y
    if nm > 12
        nm = 1
        ny = y + 1
    endif
    pe = as_string(ny) + "-" + pad(as_string(nm), 1, 2, "0") + "-01"
    return ps, pe
end

def next_day(date_str)
    result =| date -d "{date_str} + 1 day" +%Y-%m-%d 2>/dev/null
    if result.okay
        d = $st result.out
        on len(d) == 10 do return d
    endif
    # Manual fallback
    y = as_int(substr(date_str, 0, 4))
    m = as_int(substr(date_str, 5, 2))
    d = as_int(substr(date_str, 8, 2)) + 1
    dim = [0, 31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31]
    if y % 4 == 0 && (y % 100 != 0 || y % 400 == 0)
        dim[2] = 29
    endif
    if d > dim[m]
        d = 1
        m = m + 1
        if m > 12
            m = 1
            y = y + 1
        endif
    endif
    return "{=as_string(y)}-{=pad(as_string(m), 1, 2, "0")}-{=pad(as_string(d), 1, 2, "0")}"
end

def period_label(start, endt)
    parts = split(start, "-")
    months = ["", "Jan", "Feb", "Mar", "Apr", "May", "Jun",
              "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"]
    return months[as_int(parts[1])] + " " + parts[0]
end

# --- Currency helpers ---

RATES = nil
CURR_CACHE = home() + "/.cache/za/awsbilling/"

def ensure_cache_dir()
    | mkdir -p {=CURR_CACHE}
    | mkdir -p {=CURR_CACHE}costs/
end

def cache_key(profile, region, start, endt, granularity, call_type)
    safe_profile = replace(profile, "[^a-zA-Z0-9_-]", "_")
    safe_region = replace(region, "[^a-zA-Z0-9_-]", "_")
    return CURR_CACHE + "costs/" + safe_profile + "_" + safe_region + "_" + start + "_" + endt + "_" + granularity + "_" + call_type + ".json"
end

def cache_load(profile, region, start, endt, granularity, call_type)
    path = cache_key(profile, region, start, endt, granularity, call_type)
    if not is_file(path)
        return nil
    endif
    cached = json_decode($in path)
    if cached == nil
        return nil
    endif
    ts = cached["timestamp"]
    if ts == nil
        return nil
    endif
    age = epoch_time() - ts
    on age > 7200 do return nil
    return cached["data"]
end

def cache_save(profile, region, start, endt, granularity, call_type, data)
    ensure_cache_dir()
    path = cache_key(profile, region, start, endt, granularity, call_type)
    json_encode(map(.timestamp epoch_time(), .data data)) $out path
end

def cache_clear()
    | rm -rf {=CURR_CACHE}costs/*
end

def cleanup_old_cache()
    cutoff = epoch_time() - 172800
    cache_dir = CURR_CACHE + "costs/"

    if is_dir(cache_dir)
        files = glob("*", cache_dir)
        foreach f in files
            if not is_file(f)
                continue
            endif
            s = stat(f)
            if s != nil && s["modtime"] < cutoff
                delete(f)
            endif
        endfor
    endif

    # Also clean old rates files (daily, so 1-day cutoff)
    rates_files = glob("rates_*.json", CURR_CACHE)
    rate_cutoff = epoch_time() - 86400
    foreach f in rates_files
        if not is_file(f)
            continue
        endif
        s = stat(f)
        if s != nil && s["modtime"] < rate_cutoff
            delete(f)
        endif
    endfor
end

def load_rates()
    today = `{=as_string(time_year())}-{=pad(as_string(time_month()), 1, 2, "0")}-{=pad(as_string(time_dom()), 1, 2, "0")}`
    cache_file = CURR_CACHE + "rates_{today}.json"
    if is_file(cache_file)
        cached = json_decode($in cache_file)
        if cached != nil
            rates_map = cached["rates"]
            if rates_map != nil
                @RATES = cached
                return
            endif
        endif
        | rm -f {cache_file}
    endif
    spinner_show("Fetching exchange rates")
    result =| curl -s "https://api.frankfurter.dev/v1/latest?base=USD"
    spinner_clear()
    if not result.okay
        println "[#1]Failed to fetch exchange rates.[##][#-]"
        println "[#1]", result.err, "[##][#-]"
        return
    endif
    @RATES = json_decode(result.out)
    ensure_cache_dir()
    result.out $out cache_file
end

def get_rate(code)
    on code == "USD" do return 1.0
    on RATES == nil do return 1.0
    rates_map = RATES["rates"]
    on rates_map == nil do return 1.0
    rate_val = rates_map[code]
    on rate_val == nil do return 1.0
    return as_float(rate_val)
end

def curr_symbol(code)
    foreach c in CURRENCIES
        on c.code == code do return c.symbol
    endfor
    return "$"
end

def convert_and_fmt(usd_amount, code)
    return format_currency(usd_amount * get_rate(code), curr_symbol(code))
end

