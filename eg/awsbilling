def show_topn_menu(current_top)
    heading("Filter Services", "Enter=select  Q=cancel")

    opts = [
        "  All Services  ",
        "  Top 10  ",
        "  Top 20  ",
        "  Top 30  ",
        "  Top 40  ",
        "  Top 50  ",
        "  [back]  "
    ]

    selected_idx = current_top / 10
    on selected_idx < 0 do selected_idx = 0
    on selected_idx > 5 do selected_idx = 0

    m = map(.row 4, .col 4, .title "Top-N Filter", .height 0, .width 40,
            .options opts, .prompt "Show:", .cursor "[#b1][#6]>[##][#-]", .index selected_idx, .border true)
    s = map(.fill true, .bg "0", .fg "7", .hi_bg "1", .hi_fg "6",
             .border map(.bg "0", .fg "7"))

    menu = tui_menu(m, s)
    on menu.Cancel do return current_top, true
    idx = menu.Result - 1
    on idx < 0 || idx >= 6 do return current_top, true
    if idx == 0
        return 0, false
    endif
    return idx * 10, false
end

def show_cost_table(costs, profile, region, curr_code, period_lbl, forecast_val, sort_mode, top_n, total_count, hide_zero, granularity, prev_costs_map)
    cls
    at 1, 1
    println "[#b1][#6]  AWS Billing  [##][#-]"
    at 2, 1
    if curr_code != "USD"
        println "[#3]  Profile: ", profile, "  Region: ", region, "  Period: ", period_lbl, "  Rate: 1 USD = ", prec(get_rate(curr_code).as_bigf, 4), " ", curr_code, "[##][#-]"
    else
        println "[#3]  Profile: ", profile, "  Region: ", region, "  Period: ", period_lbl, "[##][#-]"
    endif

    rows = []
    total_usd = 0.0
    filtered = []
    foreach c in costs
        on hide_zero && c.cost == 0.0 do continue
        append_to(ref filtered, c)
        total_usd = total_usd + c.cost
    endfor

    cost_w = 16
    on curr_code != "USD" do cost_w = 30
    svc_w = max([20, term_w() - 67 - (cost_w - 16)]).as_int
    foreach c in filtered
        cost_display = convert_and_fmt(c.cost, curr_code)
        on curr_code != "USD" do cost_display = cost_display + " (" + format_currency(c.cost, "$") + ")"
        anomaly = ""
        on prev_costs_map != nil do anomaly = anomaly_flag(c.cost, prev_costs_map[c.service])
        svc_name = c.service + anomaly
        append_to(ref rows, costrow(
            .service trunc(svc_name, svc_w, "…"),
            .cost c.cost,
            .cost_str cost_display,
            .pct c.pct,
            .pct_val c.pct_val,
            .sort_val c.sort_val,
            .bar c.bar
        ))
    endfor

    t = map(.format "aos", .data rows, .headers true, .row 4, .col 2, .height term_h()-8, .width term_w()-6)
    t["display"] = [0, 2, 3, 6]
    t["sizes"] = [svc_w, cost_w, 10, 20]
    if granularity == "DAILY"
        t["options"] = ["Date", "Cost (" + curr_code + ")", "Share", "Relative"]
    else
        t["options"] = ["Service", "Cost (" + curr_code + ")", "Share", "Usage"]
    endif

    s = map(
        .border map(.ih "", .iv "\u2502", .tl "\u2554", .tr "\u2557", .bl "\u255a", .br "\u255d", .tm "\u2550", .bm "\u2550", .lm "\u2502", .rm "\u2502"),
        .hi_bg "[#b1]", .hi_fg "[#6]",
        .select_bg "1", .select_fg "7",
        .list ["", "", "[#2]", "[#3]", "", "", "[#4]"]
    )

    filter_text = ""
    on top_n > 0 do filter_text = "  (Top " + as_string(top_n) + " of " + as_string(total_count) + ")"
    on hide_zero do filter_text = filter_text + "  (Hide $0)"
    on granularity == "DAILY" do filter_text = filter_text + "  (Daily)"
    sort_text = " [cost \u2193]"
    on sort_mode == "cost_asc" do sort_text = " [cost \u2191]"
    on sort_mode == "name" do sort_text = " [name A-Z]"
    at term_h()-3, 2
    println "[#b1][#6]  Total: ", convert_and_fmt(total_usd, curr_code), "  Forecast: ", forecast_val != nil ? convert_and_fmt(forecast_val, curr_code) : "N/A", sort_text, filter_text, "  [##][#-]"
    at term_h()-2, 2
    println "[#3]  Enter=details  S=sort  C=currency  F=forecast  O=options  V=chart  H=hide$0  T=topN  P=period  D=daily  I=info  Q=quit[##][#-]"

    return tui_table_select(t, s)
end

