# --- TUI helpers ---

def heading(subtitle, hint)
    cls
    at 1, 1
    println "[#b1][#6]  AWS Billing - ", subtitle, "  [##][#-]"
    at 2, 1
    println "[#3]", hint, "[##][#-]"
end

def heading_err(subtitle, msg)
    cls
    at 1, 1
    println "[#b1][#6]  AWS Billing - ", subtitle, "  [##][#-]"
    at 3, 1
    println "[#1]", msg, "[##][#-]"
end

# --- Spinner ---

SPINNER_FRAMES = ["\u280b", "\u2819", "\u2839", "\u2838", "\u283c", "\u2834", "\u2826", "\u2827", "\u2807", "\u280f"]
spin_idx = 0

def spinner_show(msg)
    @spin_idx = (spin_idx + 1) % len(SPINNER_FRAMES)
    at 3, 1
    clear_line(3, 1)
    print "[#3]  {=SPINNER_FRAMES[spin_idx]} {msg}...[##][#-]"
end

def spinner_clear()
    at 3, 1
    clear_line(3, 1)
end

def async_fetch(profile, region, cost_start, cost_endt, forecast_start, forecast_endt, sort_mode, granularity)
    if granularity == "DAILY"
        costs, err = fetch_daily_costs(profile, region, cost_start, cost_endt)
    else
        costs, err = fetch_costs(profile, region, cost_start, cost_endt)
    endif
    on costs == nil do return map(.costs nil, .forecast nil, .prev_costs_map nil, .err err)
    sort_costs(costs, sort_mode)
    forecast, ferr = fetch_forecast(profile, region, forecast_start, forecast_endt)
    prev_start, prev_end = prev_period(cost_start)
    prev_map, _ = fetch_prev_month_costs(profile, region, prev_start, prev_end)
    return map(.costs costs, .forecast forecast, .prev_costs_map prev_map, .err nil)
end

def async_load(profile, region, cost_start, cost_endt, forecast_start, forecast_endt, sort_mode, granularity)
    heading("Loading", "Please wait...")
    var h map
    ASYNC h async_fetch(profile, region, cost_start, cost_endt, forecast_start, forecast_endt, sort_mode, granularity) "result"
    while true
        spinner_show("Fetching cost data")
        res = await(ref h, false)
        break if len(h) == 0
        pause 50
    endwhile
    spinner_clear()
    return res["result"]
end

# --- Date helpers ---

def this_month_period()
    y = as_string(time_year())
    m = pad(as_string(time_month()), 1, 2, "0")
    start = "{y}-{m}-01"
    nm = time_month() + 1
    ny = y
    if nm > 12
        nm = 1
        ny = as_string(time_year() + 1)
    endif
    nms = pad(as_string(nm), 1, 2, "0")
    end_str = "{ny}-{nms}-01"
    return start, end_str
end

def prev_month_period()
    y = as_string(time_year())
    m = time_month()
    pm = m - 1
    py = y
    if pm < 1
        pm = 12
        py = as_string(as_int(y) - 1)
    endif
    start = `{py}-{=pad(as_string(pm), 1, 2, "0")}-01`
    end_str = `{y}-{=pad(as_string(m), 1, 2, "0")}-01`
    return start, end_str
end

def forecast_period()
    y = as_string(time_year())
    m = pad(as_string(time_month()), 1, 2, "0")
    d = pad(as_string(time_dom()), 1, 2, "0")
    start = "{y}-{m}-{d}"
    nm = time_month() + 1
    ny = y
    if nm > 12
        nm = 1
        ny = as_string(time_year() + 1)
    endif
    nms = pad(as_string(nm), 1, 2, "0")
    end_str = "{ny}-{nms}-01"
    return start, end_str
end

def prev_period(start)
    y = as_int(substr(start, 0, 4))
    m = as_int(substr(start, 5, 2))
    m = m - 1
    if m < 1
        m = 12
        y = y - 1
    endif
    ps = as_string(y) + "-" + pad(as_string(m), 1, 2, "0") + "-01"
    nm = m + 1
    ny = y
    if nm > 12
        nm = 1
        ny = y + 1
    endif
    pe = as_string(ny) + "-" + pad(as_string(nm), 1, 2, "0") + "-01"
    return ps, pe
end

def period_label(start, endt)
    parts = split(start, "-")
    months = ["", "Jan", "Feb", "Mar", "Apr", "May", "Jun",
              "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"]
    return months[as_int(parts[1])] + " " + parts[0]
end

# --- Currency helpers ---

RATES = nil
CURR_CACHE = home() + "/.cache/za/awsbilling/"

def ensure_cache_dir()
    | mkdir -p {=CURR_CACHE}
end

def load_rates()
    today = `{=as_string(time_year())}-{=pad(as_string(time_month()), 1, 2, "0")}-{=pad(as_string(time_dom()), 1, 2, "0")}`
    cache_file = CURR_CACHE + "rates_{today}.json"
    if is_file(cache_file)
        cached = json_decode($in cache_file)
        if cached != nil
            rates_map = cached["rates"]
            if rates_map != nil
                @RATES = cached
                return
            endif
        endif
        | rm -f {cache_file}
    endif
    spinner_show("Fetching exchange rates")
    result =| curl -s "https://api.frankfurter.dev/v1/latest?base=USD"
    spinner_clear()
    if not result.okay
        println "[#1]Failed to fetch exchange rates.[##][#-]"
        println "[#1]", result.err, "[##][#-]"
        return
    endif
    @RATES = json_decode(result.out)
    ensure_cache_dir()
    result.out $out cache_file
end

def get_rate(code)
    on code == "USD" do return 1.0
    on RATES == nil do return 1.0
    rates_map = RATES["rates"]
    on rates_map == nil do return 1.0
    rate_val = rates_map[code]
    on rate_val == nil do return 1.0
    return as_float(rate_val)
end

def curr_symbol(code)
    foreach c in CURRENCIES
        on c.code == code do return c.symbol
    endfor
    return "$"
end

def convert_and_fmt(usd_amount, code)
    return format_currency(usd_amount * get_rate(code), curr_symbol(code))
end

# --- Structs for table display ---

struct costrow
    service     string
    cost        float
    cost_str    string
    pct         string
    pct_val     float
    sort_val    float
    bar         string

es

# --- Sorting ---

def sort_costs(costs, mode)
    n = len(costs)
    on n < 2 do return
    for i = 0 to n - 2
        for j = 0 to n - i - 2
            swap = false
            if mode == "name"
                a = lower(costs[j].service)
                b = lower(costs[j+1].service)
                on a > b do swap = true
            else
                a = costs[j].sort_val
                b = costs[j+1].sort_val
                if mode == "cost_desc"
                    on a < b do swap = true
                else
                    on a > b do swap = true
                endif
            endif
            if swap
                tmp = costs[j]
                costs[j] = costs[j+1]
                costs[j+1] = tmp
            endif
        endfor
    endfor
end

# --- AWS helpers ---

def check_aws_cli()
    result =| aws --version 2>&1
    return result.okay
end

def aws_ce(profile, args)
    cmd = "aws ce " + args + " --output json 2>&1"
    on profile != "" do cmd = "AWS_PROFILE={profile} " + cmd
    result =| {cmd}
    if not result.okay
        err_msg = result.err
        on err_msg == "" do err_msg = trim(result.out)
        return nil, err_msg
    endif
    return json_decode(result.out), nil
end

def discover_profiles()
    profiles = []
    creds_path = home() + "/.aws/credentials"
    config_path = home() + "/.aws/config"
    
    if is_file(creds_path)
        raw = $in creds_path
        lines = split(raw, "\n")
        foreach line in lines
            line = replace(line, "^\s+|\s+$", "")
            continue if not line ~ "^\["
            name = replace(line, "^\[", "")
            name = replace(name, "\]$", "")
            on not name in profiles do append_to(ref profiles, name)
        endfor
    endif
    
    if is_file(config_path)
        raw = $in config_path
        lines = split(raw, "\n")
        foreach line in lines
            line = replace(line, "^\s+|\s+$", "")
            continue if not line ~ "^\[profile\s"
            name = replace(line, "^\[profile\s+", "")
            name = replace(name, "\]$", "")
            on not name in profiles do append_to(ref profiles, name)
        endfor
    endif
    
    return profiles
end

def discover_regions(profile)
    regions = []
    cy = as_string(time_year())
    cm = as_int(time_month())
    sm = cm - 3
    sy = cy
    if sm < 1
        sm = sm + 12
    endif
    if sm > cm
        sy = as_string(as_int(cy) - 1)
    endif
    start_str = `{sy}-{=pad(as_string(sm), 1, 2, "0")}-01`
    end_str = `{cy}-{=pad(as_string(cm), 1, 2, "0")}-01`
    args = `get-dimension-values --dimension REGION --time-period Start={start_str},End={end_str}`
    data, err = aws_ce(profile, args)
    if data == nil
        return regions, "aws ce failed: " + err
    endif
    vals = data["DimensionValues"]
    on vals == nil do return regions, "No DimensionValues in AWS response"
    foreach v in vals
        code = v["Value"]
        continue if code == nil
        continue if code == ""
        label = code
        attrs = data["DimensionValueAttributes"]
        if attrs != nil
            foreach a in attrs
                continue if a["Value"] != code
                dn = a["Attributes"]["displayName"]
                on dn != nil do label = "{dn} ({code})"
            endfor
        endif
        append_to(ref regions, map(.code code, .label label))
    endfor
    return regions, ""
end

def fetch_costs(profile, region, start, endt)
    args = "get-cost-and-usage --time-period Start={start},End={endt} --granularity MONTHLY --metrics AmortizedCost --group-by Type=DIMENSION,Key=SERVICE"
    on region != "" do args = args + " --filter '" + json_encode(map(.Dimensions map(.Key "REGION", .Values [region]))) + "'"
    data, err = aws_ce(profile, args)
    on data == nil do return nil, err
    results = data["ResultsByTime"]
    on results == nil do return nil, "No ResultsByTime in response"
    on len(results) == 0 do return nil, "Empty ResultsByTime"
    period = results[0]
    groups = period["Groups"]
    on groups == nil do return nil, "No Groups in response"
    on len(groups) == 0 do return nil, "No cost data found"
    costs = []
    total = 0.0
    foreach g in groups
        amount_str = g["Metrics"]["AmortizedCost"]["Amount"]
        continue if amount_str == nil
        amount = as_float(amount_str)
        svc_name = g["Keys"][0]
        on svc_name == nil do svc_name = "Unknown"
        append_to(ref costs, costrow(
            .service svc_name,
            .cost amount,
            .cost_str "",
            .pct "",
            .pct_val 0.0,
            .sort_val amount,
            .bar ""
        ))
        total = total + amount
    endfor
    on len(costs) == 0 do return nil, "No cost data parsed"
    for i = 0 to len(costs)-1
        pct_val = 0.0
        on total > 0 do pct_val = costs[i].cost / total * 100.0
        costs[i].pct_val = pct_val
        pct_str = "{=as_string(pct_val.as_bigf, 3)}%"
        on pct_str ~ "e-" do pct_str = "<0.001%"
        costs[i].pct = pct_str
        costs[i].bar = progress_bar(pct_val, 20, "\u2588", "\u2591")
    endfor
    sort_costs(costs, "cost_desc")
    return costs, nil
end

def fetch_daily_costs(profile, region, start, endt)
    args = "get-cost-and-usage --time-period Start={start},End={endt} --granularity DAILY --metrics AmortizedCost"
    on region != "" do args = args + " --filter '" + json_encode(map(.Dimensions map(.Key "REGION", .Values [region]))) + "'"
    data, err = aws_ce(profile, args)
    on data == nil do return nil, err
    results = data["ResultsByTime"]
    on results == nil do return nil, "No ResultsByTime in response"
    on len(results) == 0 do return nil, "Empty ResultsByTime"
    costs = []
    total = 0.0
    max_cost = 0.0
    foreach period in results
        amount_str = period["Total"]["AmortizedCost"]["Amount"]
        continue if amount_str == nil
        amount = as_float(amount_str)
        date_label = period["TimePeriod"]["Start"]
        on date_label == nil do date_label = "Unknown"
        append_to(ref costs, costrow(
            .service date_label,
            .cost amount,
            .cost_str "",
            .pct "",
            .pct_val 0.0,
            .sort_val amount,
            .bar ""
        ))
        total = total + amount
        on amount > max_cost do max_cost = amount
    endfor
    on len(costs) == 0 do return nil, "No cost data parsed"
    for i = 0 to len(costs)-1
        pct_val = 0.0
        on total > 0 do pct_val = costs[i].cost / total * 100.0
        costs[i].pct_val = pct_val
        pct_str = "{=as_string(pct_val.as_bigf, 3)}%"
        on pct_str ~ "e-" do pct_str = "<0.001%"
        costs[i].pct = pct_str
        bar_pct = 0.0
        on max_cost > 0 do bar_pct = costs[i].cost / max_cost * 100.0
        costs[i].bar = progress_bar(bar_pct, 20, "\u2588", "\u2591")
    endfor
    return costs, nil
end

def fetch_forecast(profile, region, start, endt)
    args = "get-cost-forecast --time-period Start={start},End={endt} --metric AMORTIZED_COST --granularity MONTHLY"
    on region != "" do args = args + " --filter '" + json_encode(map(.Dimensions map(.Key "REGION", .Values [region]))) + "'"
    data, err = aws_ce(profile, args)
    on data == nil do return nil, err
    total = data["Total"]
    on total == nil do return nil, "No Total in forecast"
    amount_str = total["Amount"]
    on amount_str == nil do return nil, "No Amount in forecast"
    return as_float(amount_str), nil
end

def fetch_prev_month_costs(profile, region, start, endt)
    args = "get-cost-and-usage --time-period Start={start},End={endt} --granularity MONTHLY --metrics AmortizedCost --group-by Type=DIMENSION,Key=SERVICE"
    on region != "" do args = args + " --filter '" + json_encode(map(.Dimensions map(.Key "REGION", .Values [region]))) + "'"
    data, err = aws_ce(profile, args)
    on data == nil do return nil, err
    results = data["ResultsByTime"]
    on results == nil do return nil, "No ResultsByTime"
    on len(results) == 0 do return nil, "Empty ResultsByTime"
    period = results[0]
    groups = period["Groups"]
    on groups == nil do return nil, "No Groups"
    prev = map()
    foreach g in groups
        amount_str = g["Metrics"]["AmortizedCost"]["Amount"]
        continue if amount_str == nil
        svc = g["Keys"][0]
        on svc == nil do svc = "Unknown"
        prev[svc] = as_float(amount_str)
    endfor
    return prev, nil
end

def anomaly_flag(cost, prev_cost)
    on prev_cost == nil do return ""
    on prev_cost == 0.0 do return ""
    on cost > prev_cost * 1.5 do return " \u25b2"
    return ""
end

def fetch_service_daily(profile, region, service_name, start, endt)
    args = "get-cost-and-usage --time-period Start={start},End={endt} --granularity DAILY --metrics AmortizedCost"
    filter_expr = json_encode(map(.And [
        map(.Dimensions map(.Key "REGION", .Values [region])),
        map(.Dimensions map(.Key "SERVICE", .Values [service_name]))
    ]))
    on region != "" do args = args + " --filter '" + filter_expr + "'"
    on region == "" do args = args + " --filter '" + json_encode(map(.Dimensions map(.Key "SERVICE", .Values [service_name]))) + "'"
    data, err = aws_ce(profile, args)
    on data == nil do return nil, err
    results = data["ResultsByTime"]
    on results == nil do return nil, "No ResultsByTime"
    days = []
    max_cost = 0.0
    foreach period in results
        amount_str = period["Total"]["AmortizedCost"]["Amount"]
        continue if amount_str == nil
        amount = as_float(amount_str)
        date_str = period["TimePeriod"]["Start"]
        on date_str == nil do date_str = "?"
        append_to(ref days, map(.date date_str, .cost amount))
        on amount > max_cost do max_cost = amount
    endfor
    return days, max_cost, nil
end

def render_mini_chart(days, max_cost, curr_code)
    if len(days) == 0
        return "No daily data"
    endif
    lines = []
    foreach d in days
        bar = ""
        on max_cost > 0 do bar = progress_bar(d.cost / max_cost * 100.0, 20, "\u2588", "\u2591")
        append_to(ref lines, "  " + d.date + "  " + convert_and_fmt(d.cost, curr_code) + "  " + bar)
    endfor
    return join(lines, "\n")
end

