    at 20, 5
    println "[#6]P         [#3]Toggle period (this/last month)[##]"
    at 22, 5
    println "[#6]D         [#3]Toggle daily/monthly granularity[##]"
    at 24, 5
    println "[#6]I         [#3]This help screen[##]"
    at 26, 5
    println "[#6]Q         [#3]Quit[##]"
    at 28, 5
    println "[#3]Press any key to return...[##][#-]"
    keypress()
end

def show_error(msg)
    cls
    at term_h()/2 - 2, 4
    println "[#1]", trunc(msg, term_w() - 8, "\u2026"), "[##][#-]"
    at term_h()/2, 4
    println "[#3]Press any key...[##][#-]"
    keypress()
end

def export_costs(costs, profile, region, curr_code, period_lbl, path)
    buf = "AWS Billing Report\n"
    buf = buf + "Profile: " + profile + "  Region: " + region + "  Period: " + period_lbl + "\n"
    buf = buf + "\n"
    buf = buf + "Service,Cost (" + curr_code + "),Share\n"
    foreach c in costs
        buf = buf + "\"" + c.service + "\"," + convert_and_fmt(c.cost, curr_code) + "," + c.pct + "\n"
    endfor
    dir = replace(path, "/[^/]+$", "")
    on dir != "" && dir != path do | mkdir -p {dir}
    buf $out path
end

def save_session(profile, region, curr_code, sort_mode, top_n, is_prev, hide_zero, granularity)
    session = map(.profile profile, .region region, .currency curr_code, .sort_mode sort_mode, .top_n top_n, .is_prev is_prev, .hide_zero hide_zero, .granularity granularity)
    ensure_cache_dir()
    json_encode(session) $out CURR_CACHE + "session.json"
end

def load_session()
    path = CURR_CACHE + "session.json"
    on not is_file(path) do return nil
    return json_decode($in path)
end

def profile_valid(profiles, name)
    foreach p in profiles
        on p == name do return true
    endfor
    return false
end

def show_main_menu(sort_mode, period_lbl, top_n)
    heading("Actions", "Enter=select  Q=cancel")

    opts = [
        "  Switch Profile  ",
        "  Switch Region  ",
        "  Change Currency  ",
        "  Switch Period  ",
        "  Show Forecast  ",
        "  Refresh Data  ",
        "  Export Data  ",
        "  Quit  "
    ]

    m = map(.row 4, .col 4, .title "Actions", .height 0, .width 40,
            .options opts, .prompt "Select action:", .cursor "[#b1][#6]>[##][#-]", .index 0, .border true)
    s = map(.fill true, .bg "0", .fg "7", .hi_bg "1", .hi_fg "6",
             .border map(.bg "0", .fg "7"))

    menu = tui_menu(m, s)
    on menu.Cancel do return "quit"
    case menu.Result
    is 1 ; return "profile"
    is 2 ; return "region"
    is 3 ; return "currency"
    is 4 ; return "period"
    is 5 ; return "forecast"
    is 6 ; return "refresh"
    is 7 ; return "export"
    is 8 ; return "quit"
    endcase
    return "quit"
end

# --- Main ---

tui_screen(1)

# Load session defaults
session = load_session()
curr_profile = ""
curr_region = ""
curr_code = "USD"
sort_mode = "cost_desc"
top_n = 0
is_prev = false
hide_zero = false
granularity = "MONTHLY"
on session != nil do curr_profile = session["profile"]
on session != nil do curr_region = session["region"]
on session != nil do curr_code = session["currency"]
on session != nil do sort_mode = session["sort_mode"]
on session != nil do top_n = session["top_n"]
on session != nil do is_prev = session["is_prev"]
on session != nil do hide_zero = session["hide_zero"]
on session != nil do granularity = session["granularity"]

while
    cursoroff()

    cleanup_old_cache()

    if not check_aws_cli()
        show_error("AWS CLI not found. Please install and configure it.")
        break
    endif

    profiles = discover_profiles()
    if len(profiles) == 0
        show_error("No AWS profiles found in ~/.aws/config")
        break
    endif

    if len(profiles) == 1
        curr_profile = profiles[0]
    else
        if curr_profile == "" || not profile_valid(profiles, curr_profile)
            curr_profile, cancelled = show_profile_menu(profiles)
        endif
    endif
    break if curr_profile == ""

    if curr_region == ""
        curr_region, cancelled = show_region_menu(curr_profile, curr_region)
    endif

    load_rates()

    start_t, end_t = this_month_period()
    forecast_start, forecast_end = forecast_period()
    period_lbl = period_label(start_t, end_t)
    is_prev = false

    fetch_result = async_load(curr_profile, curr_region, start_t, end_t, forecast_start, forecast_end, sort_mode, granularity, false)
    if fetch_result["costs"] == nil
        show_error("Failed to fetch costs: {=fetch_result["err"]}")
        break
    endif
    all_costs = fetch_result["costs"]
    costs = all_costs
    forecast_val = fetch_result["forecast"]
    prev_costs_map = fetch_result["prev_costs_map"]

    prev_w = term_w()
    prev_h = term_h()

    while
        cursoroff()
        if term_w() != prev_w || term_h() != prev_h
            prev_w = term_w()
            prev_h = term_h()
        endif
        res = show_cost_table(costs, curr_profile, curr_region, curr_code, period_lbl, forecast_val, sort_mode, top_n, len(all_costs), hide_zero, granularity, prev_costs_map)
        if res.Back || $lc res.Action == "o"
            action = show_main_menu(sort_mode, period_lbl, top_n)
            case action
            is "profile"
                curr_profile, cancelled = show_profile_menu(profiles)
                break if curr_profile == ""
                fetch_result = async_load(curr_profile, curr_region, start_t, end_t, forecast_start, forecast_end, sort_mode, granularity, false)
                if fetch_result["costs"] == nil
                    show_error("Failed to fetch costs: {=fetch_result["err"]}")
                    continue
                endif
                all_costs = fetch_result["costs"]
                costs = all_costs
                on top_n > 0 && len(costs) > top_n do costs = costs[:top_n]
                forecast_val = fetch_result["forecast"]
                prev_costs_map = fetch_result["prev_costs_map"]
            is "region"
                curr_region, cancelled = show_region_menu(curr_profile, curr_region)
                fetch_result = async_load(curr_profile, curr_region, start_t, end_t, forecast_start, forecast_end, sort_mode, granularity, false)
                if fetch_result["costs"] == nil
                    show_error("Failed to fetch costs: {=fetch_result["err"]}")
                    continue
                endif
                all_costs = fetch_result["costs"]
                costs = all_costs
                on top_n > 0 && len(costs) > top_n do costs = costs[:top_n]
                forecast_val = fetch_result["forecast"]
                prev_costs_map = fetch_result["prev_costs_map"]
            is "currency"
                curr_code, cancelled = show_currency_menu(curr_code)
            is "period"
                if not is_prev
                    start_t, end_t = prev_month_period()
                    is_prev = true
                else
                    start_t, end_t = this_month_period()
                    is_prev = false
                endif
                period_lbl = period_label(start_t, end_t)
                fetch_result = async_load(curr_profile, curr_region, start_t, end_t, forecast_start, forecast_end, sort_mode, granularity, false)
                if fetch_result["costs"] == nil
                    show_error("Failed to fetch costs: {=fetch_result["err"]}")
                    continue
                endif
                all_costs = fetch_result["costs"]
                costs = all_costs
                on top_n > 0 && len(costs) > top_n do costs = costs[:top_n]
                forecast_val = fetch_result["forecast"]
                prev_costs_map = fetch_result["prev_costs_map"]
            is "forecast"
                show_forecast_detail(forecast_val, curr_code, period_lbl)
            is "refresh"
                cache_clear()
                fetch_result = async_load(curr_profile, curr_region, start_t, end_t, forecast_start, forecast_end, sort_mode, granularity, true)
                if fetch_result["costs"] == nil
                    show_error("Failed to fetch costs: {=fetch_result["err"]}")
                    continue
                endif
                all_costs = fetch_result["costs"]
                costs = all_costs
                on top_n > 0 && len(costs) > top_n do costs = costs[:top_n]
                forecast_val = fetch_result["forecast"]
                prev_costs_map = fetch_result["prev_costs_map"]
            is "export"
                heading("Export Data", "Enter filename (or leave empty for default)")
                default_name = "awsbilling_" + replace(period_lbl, " ", "_") + ".csv"
                prompt filename "Filename: "
                on filename == "" do filename = default_name
                on filename ~ "^~" do filename = home() + substr(filename, 1, len(filename)-1)
                if not filename ~ "^/"
                    filename = home() + "/" + filename
                endif
                export_costs(costs, curr_profile, curr_region, curr_code, period_lbl, filename)
                heading("Export Complete", "")
                at 5, 5
                println "[#3]Saved to: [#6]", filename, "[##][#-]"
                at 7, 5
                println "[#3]Press any key to return...[##][#-]"
                keypress()
            is "quit"
                break
            endcase
            continue
        endif
        if $lc res.Action == "s"
            if sort_mode == "cost_desc"
                sort_mode = "cost_asc"
            else
                if sort_mode == "cost_asc"
                    sort_mode = "name"
                else
                    sort_mode = "cost_desc"
                endif
            endif
            sort_costs(costs, sort_mode)
            continue
        endif
        if $lc res.Action == "c"
            curr_code, cancelled = show_currency_menu(curr_code)
            continue
        endif
        if $lc res.Action == "f"
            show_forecast_detail(forecast_val, curr_code, period_lbl)
            continue
        endif
        if $lc res.Action == "t"
            top_n, cancelled = show_topn_menu(top_n)
            costs = all_costs
            on top_n > 0 && len(costs) > top_n do costs = costs[:top_n]
            continue
        endif
        if $lc res.Action == "h"
            if hide_zero
                hide_zero = false
            else
                hide_zero = true
            endif
            continue
        endif
        if $lc res.Action == "p"
            if not is_prev
                start_t, end_t = prev_month_period()
                is_prev = true
            else
                start_t, end_t = this_month_period()
                is_prev = false
            endif
            period_lbl = period_label(start_t, end_t)
            fetch_result = async_load(curr_profile, curr_region, start_t, end_t, forecast_start, forecast_end, sort_mode, granularity, false)
            if fetch_result["costs"] == nil
                show_error("Failed to fetch costs: {=fetch_result["err"]}")
                continue
            endif
            all_costs = fetch_result["costs"]
            costs = all_costs
            on top_n > 0 && len(costs) > top_n do costs = costs[:top_n]
            forecast_val = fetch_result["forecast"]
            prev_costs_map = fetch_result["prev_costs_map"]
            continue
        endif
        if $lc res.Action == "d"
            if granularity == "MONTHLY"
                granularity = "DAILY"
                sort_mode = "name"
            else
                granularity = "MONTHLY"
                sort_mode = "cost_desc"
            endif
            fetch_result = async_load(curr_profile, curr_region, start_t, end_t, forecast_start, forecast_end, sort_mode, granularity, false)
            if fetch_result["costs"] == nil
                show_error("Failed to fetch costs: {=fetch_result["err"]}")
                continue
            endif
            all_costs = fetch_result["costs"]
            costs = all_costs
            on top_n > 0 && len(costs) > top_n do costs = costs[:top_n]
            forecast_val = fetch_result["forecast"]
            prev_costs_map = fetch_result["prev_costs_map"]
            continue
        endif
        if $lc res.Action == "v"
            if granularity == "MONTHLY"
                show_monthly_chart(all_costs, curr_code, period_lbl, hide_zero)
            endif
            continue
        endif
        if $lc res.Action == "i"
            show_help()
            continue
        endif
        break if res.Cancel

        sel = res.Result.as_int
        continue if sel < 0 || sel >= len(costs)
        chosen = costs[sel]

        if granularity == "DAILY"
            heading("Date Details", "")
            at 5, 5
            println "[#3]Date:  [#6]", trunc(chosen.service, term_w() - 14, "…"), "[##][#-]"
            at 7, 5
            println "[#3]Cost:    [#6]", convert_and_fmt(chosen.cost, curr_code), "[##][#-]"
            at 9, 5
            println "[#3]Share:   [#6]", chosen.pct, "[##][#-]"
            
            # Show previous month comparison if available
            prev_cost = nil
            on prev_costs_map != nil do prev_cost = prev_costs_map[chosen.service]
            if prev_cost != nil
                delta = ((chosen.cost - prev_cost) / prev_cost * 100.0)
                delta_str = as_string(delta.as_bigf, 1) + "%"
                at 11, 5
                if delta > 0
                    println "[#3]Previous: [#6]", convert_and_fmt(prev_cost, curr_code), "  [\u25b2 +", delta_str, "][##][#-]"
                else
                    if delta < 0
                        println "[#3]Previous: [#6]", convert_and_fmt(prev_cost, curr_code), "  [\u25bc ", delta_str, "][##][#-]"
                    else
                        println "[#3]Previous: [#6]", convert_and_fmt(prev_cost, curr_code), "  [= 0%][##][#-]"
                    endif
                endif
            endif

            # Fetch and show service breakdown for this day
            svc_costs, svc_max, svc_err = fetch_day_services(curr_profile, curr_region, chosen.service)
            if svc_err == nil && len(svc_costs) > 0
                if term_w() >= 100
                    at 13, 5
                    println "[#3]Services:[##][#-]"
                    chart_res = render_service_chart(svc_costs, svc_max, curr_code, 14, 5, 12, 18)
                    print "[#2]", chart_res.text, "[##][#-]"
                    at term_h() - 1, 5
                    println "[#3]Press any key to return...[##][#-]"
                else
                    at 13, 5
                    println "[#3]Services:[##][#-]"
                    lines = []
                    foreach s in svc_costs
                        on s.cost == 0.0 do continue
                        bar = ""
                        on svc_max > 0 do bar = progress_bar(s.cost / svc_max * 100.0, 20, "\u2588", "\u2591")
                        append_to(ref lines, "  " + trunc(s.service, 25, "\u2026") + "  " + convert_and_fmt(s.cost, curr_code) + "  " + bar)
                    endfor
                    at 15, 5
                    println "[#2]", join(lines, "\n"), "[##][#-]"
                    at 15 + len(lines), 5
                    println "[#3]Press any key to return...[##][#-]"
                endif
            else
                at 13, 5
                println "[#3]Press any key to return...[##][#-]"
            endif
        else
            heading("Service Details", "")
            at 5, 5
            println "[#3]Service: [#6]", trunc(chosen.service, term_w() - 14, "…"), "[##][#-]"
            at 7, 5
            println "[#3]Rank:    [#6]", as_string(sel + 1), " of ", as_string(len(costs)), "[##][#-]"
            at 9, 5
            println "[#3]Cost:    [#6]", convert_and_fmt(chosen.cost, curr_code), "[##][#-]"
            at 11, 5
            println "[#3]Share:   [#6]", chosen.pct, "[##][#-]"
            at 13, 5
            println "[#3]Usage:   [#6]", chosen.bar, "[##][#-]"
            
            # Show previous month comparison if available
            prev_cost = nil
            on prev_costs_map != nil do prev_cost = prev_costs_map[chosen.service]
            if prev_cost != nil
                delta = ((chosen.cost - prev_cost) / prev_cost * 100.0)
                delta_str = as_string(delta.as_bigf, 1) + "%"
                at 15, 5
                if delta > 0
                    println "[#3]Previous: [#6]", convert_and_fmt(prev_cost, curr_code), "  [\u25b2 +", delta_str, "][##][#-]"
                else
                    if delta < 0
                        println "[#3]Previous: [#6]", convert_and_fmt(prev_cost, curr_code), "  [\u25bc ", delta_str, "][##][#-]"
                    else
                        println "[#3]Previous: [#6]", convert_and_fmt(prev_cost, curr_code), "  [= 0%][##][#-]"
                    endif
                endif
            endif
            
            # Fetch and show 30-day daily chart
            days, max_day_cost, chart_err = fetch_service_daily(curr_profile, curr_region, chosen.service, start_t, end_t)
            if chart_err == nil && len(days) > 0
                if term_w() >= 100
                    chart_costs = []
                    foreach d in days
                        append_to(ref chart_costs, costrow(
                            .service d.date,
                            .cost d.cost,
                            .cost_str "",
                            .pct "",
                            .pct_val 0.0,
                            .sort_val d.cost,
                            .bar ""
                        ))
                    endfor
                    at 17, 5
                    println "[#3]Daily trend:[##][#-]"
                    chart_res = render_daily_chart(chart_costs, max_day_cost, curr_code, "", 19, 5)
                    print "[#2]", chart_res.text, "[##][#-]"
                    at term_h() - 1, 5
                    println "[#3]Press any key to return...[##][#-]"
                else
                    at 17, 5
                    println "[#3]Daily trend:[##][#-]"
                    at 19, 5
                    println "[#2]", render_mini_chart(days, max_day_cost, curr_code), "[##][#-]"
                    at 21 + len(days), 5
                    println "[#3]Press any key to return...[##][#-]"
                endif
            else
                at 17, 5
                println "[#3]Press any key to return...[##][#-]"
            endif
        endif
        keypress()
    endwhile
    save_session(curr_profile, curr_region, curr_code, sort_mode, top_n, is_prev, hide_zero, granularity)
    break
endwhile

tui_screen(0)
cursoron()
at term_h(), 1

