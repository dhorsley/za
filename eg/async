#!/usr/bin/za

define q(val)
    delay=1+rand(4)
    pause delay*100
    return as_string(val)
end

# MAIN

coproc(false)

println "Spinning async tasks"

for e = 0 to 99
    async handles q(e) "task number "+e
endfor

println "Waiting for all async tasks to start..."
delay = async_wait_startup("handles")
println ": Completed startups in {delay} µs"

while

    print "[#2]Waiting...[#-]"
    res=await("handles",false)
    println " : await() complete."

    break if len(handles)==0

    # collect current results
    foreach r in res
        output[key_r]=r
    endfor

    pause 50

endwhile

println "Collated output:"
println output.pp


