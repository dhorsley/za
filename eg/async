#!/usr/bin/za

define q(val)
    delay=1+rand(4)
    pause delay*100
    return val*3f
end

# MAIN

println "Spinning async tasks"

for e = 0 to 99
    async handles q(e) "task number "+e
endfor

println "Waiting for all async tasks to start..."
delay = async_wait_startup(ref handles)
println ": Completed startups in {delay} µs"

while

    print "[#2]Waiting...[#-]"
    res=await(ref handles,false)
    println " : await() complete."
    println " : remaining handles = {=handles.len}"

    break if len(handles)==0

    # collect current results
    foreach r in res
        output[key_r]="{r} : {=r.kind}"
    endfor

    pause 50

endwhile

println "Collated output:"
println output.pp


