#!/usr/bin/za

define q(val)
    delay=rand(4)
    pause delay*100
    return as_string(val)
end

# MAIN

coproc(false)

println "Spinning async tasks"

for e = 0 to 99
    async handles q(e) "task number "+e
endfor

println "pausing 1/4 second to allow for task warmup."
pause 250

while

    print "[#2]Waiting...[#-]"
    res=await("handles",false)
    println " : await() complete."

    on len(res)==0 do break

    # collect current results
    foreach r in res
        output[key_r]=r
    endfor

    pause 5 

endwhile

println "Collated output:"
println output.pp
