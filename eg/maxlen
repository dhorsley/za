#!/usr/bin/za

doc `
    simple function to figure max length string in a given array
    column then demonstrates using the result.
`


define longest_key(arr)
    return (arr -> `#[0].len`) . list_int . max
end

elist=[]
# flatten out values including the = delimiter
foreach i in env()
    _=fields(i,"=")
    value=F[2:].join("=")
    elist=append(elist,[F[1],value])
endfor

ln=elist.longest_key

foreach e in elist
    println "[#6]%{ln}s[#-] -> %s".format(e[0],e[1])
endfor

