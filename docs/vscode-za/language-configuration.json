{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    [
      "{",
      "}"
    ],
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ]
  ],
  "autoClosingPairs": [
    {
      "open": "{",
      "close": "}"
    },
    {
      "open": "[",
      "close": "]"
    },
    {
      "open": "(",
      "close": ")"
    },
    {
      "open": "\"",
      "close": "\"",
      "notIn": [
        "string"
      ]
    },
    {
      "open": "`",
      "close": "`",
      "notIn": [
        "string"
      ]
    }
  ],
  "surroundingPairs": [
    [
      "{",
      "}"
    ],
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ],
    [
      "\"",
      "\""
    ],
    [
      "`",
      "`"
    ]
  ],
  "indentationRules": {
    "increaseIndentPattern": "\\\\b(async|case|def|enum|for|foreach|if|struct|test|try|while)\\\\b",
    "decreaseIndentPattern": "\\\\b(end|endcase|enddef|endfor|endtest|endtry|endwhile|endif|endstruct)\\\\b"
  }
}